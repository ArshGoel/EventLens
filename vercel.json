{
  "builds": [
    {
      "src": "EventLens/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build"
    
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "EventLens/wsgi.py"
    }
  ],
  "functions": {
    "EventLens/wsgi.py": {
      "maxDuration": 60
    }
  }
}
